// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
}

model Audit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shareId   String   @unique
  tools     Json
  auditResults Json
  totalMonthlySavings Float
  totalAnnualSavings  Float
  summary   String?
  useCase   String
  teamSize  Int
  savingsTier String

  @@map("audits")
}

model Lead {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String
  companyName String?
  role      String?
  teamSize  Int?
  auditId   String
  savingsTier String

  @@map("leads")
}
