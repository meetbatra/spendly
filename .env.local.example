# DATABASE_URL: Supabase pooled Postgres connection string used by app runtime; get from Supabase Project Settings > Database.
DATABASE_URL="postgres://postgres.xxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: Direct Postgres connection string used by Prisma CLI/migrations; get from Supabase Project Settings > Database.
DIRECT_URL="postgres://postgres.xxx:password@aws-0-us-west-1.pooler.supabase.com:5432/postgres"

# SHADOW_DATABASE_URL: Optional shadow DB URL for Prisma migrate workflows; create/provision in Supabase and use its direct URL.
SHADOW_DATABASE_URL="postgres://postgres.xxx:password@aws-0-us-west-1.pooler.supabase.com:5432/postgres_shadow"

# OPENAI_API_KEY: API key for /api/summary AI-generated summaries; create in OpenAI dashboard API keys.
OPENAI_API_KEY="sk-..."

# RESEND_API_KEY: API key for lead capture confirmation emails; create in Resend dashboard API keys.
RESEND_API_KEY="re_..."

# UPSTASH_REDIS_REST_URL: Upstash Redis REST URL for API rate limiting; get from Upstash Redis database details.
UPSTASH_REDIS_REST_URL="https://...upstash.io"

# UPSTASH_REDIS_REST_TOKEN: Upstash Redis REST token for API rate limiting; get from Upstash Redis database details.
UPSTASH_REDIS_REST_TOKEN="..."

# ENABLE_AUDIT_RATE_LIMIT: Set to "true" to enforce /api/audit rate limiting (10/hour/IP); leave "false" while doing local QA runs.
ENABLE_AUDIT_RATE_LIMIT="false"

# NEXT_PUBLIC_APP_URL: Public base URL used for canonical/OG links (for example results page metadata); set to your Vercel production URL.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NODE_ENV: Runtime mode set automatically by Node/Vercel (typically development/production); do not manually set unless troubleshooting.
NODE_ENV="development"
